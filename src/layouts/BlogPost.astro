---
import type { CollectionEntry } from 'astro:content'
import FormattedDate from '@/components/FormattedDate'
import BaseLayout from '@/layouts/BaseLayout'
import Tag from '@/components/Tag'
import AuthorBox from '@/components/AuthorBox'
import Breadcrumbs from '@/components/Breadcrumbs'
import ReadingProgress from '@/components/ReadingProgress'

import type { MarkdownHeading } from 'astro'
import { Image } from 'astro:assets'
import { siteConfig } from '@/site-config'

type Props = {
	id: CollectionEntry<'blog'>['id']
	data: CollectionEntry<'blog'>['data']
	headings: MarkdownHeading[]
	readTime: string
}

const { data, readTime, headings, id } = Astro.props
/** Portrait hero assets (e.g. phone photos) must use contain, not cover. */
const heroImageContain = id === 'grapheneos-daily-driver-setup-pixel-guide'
const { title, description, pubDate, heroImage, tags, category } = data

const articleDate = pubDate.toISOString()
const canonical = new URL(`/post/${id}/`, Astro.site).href
const heroAbsoluteUrl = heroImage?.src
	? new URL(heroImage.src, Astro.site).href
	: undefined

const blogPostingJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: articleDate,
	dateModified: articleDate,
	author: {
		'@type': 'Organization',
		name: siteConfig.author,
		url: siteConfig.site,
	},
	publisher: {
		'@type': 'Organization',
		name: siteConfig.title,
		url: siteConfig.site,
		logo: {
			'@type': 'ImageObject',
			url: new URL('/brand/icon.svg', Astro.site).href,
		},
	},
	mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
	...(heroAbsoluteUrl ? { image: heroAbsoluteUrl } : {}),
	keywords: tags.join(', '),
	articleSection: category,
}
---

<BaseLayout
	title={title}
	description={description}
	image={heroImage?.src}
	articleDate={articleDate}
>
	<ReadingProgress />
	<script type='application/ld+json' set:html={JSON.stringify(blogPostingJsonLd)} />

	<article class='min-w-full md:py-4 sm:max-w-none md:max-w-none'>
		<div class='mb-6'>
			<Breadcrumbs category={category} items={[{ label: title }]} />
		</div>

		<header class='mb-8 flex flex-col justify-center items-center gap-6 text-center mt-4'>
			<div class='flex flex-col gap-4'>
				<span
					class='inline-block mx-auto text-[11px] font-bold uppercase tracking-[0.18em] text-sky-700 dark:text-sky-300'
				>
					{category}
				</span>
				<h1
					class='text-4xl md:text-5xl lg:text-[3.4rem] font-bold leading-[1.05] -tracking-wide max-w-4xl mx-auto'
				>
					{title}
				</h1>
				<p
					class='max-w-3xl mx-auto text-[15px] sm:text-[17px] leading-relaxed text-stone-600 dark:text-stone-400'
				>
					{description}
				</p>
				<div
					class='flex flex-wrap items-center justify-center gap-x-3 text-[13px] font-medium text-stone-500 dark:text-stone-400 mt-2'
				>
					<span class='uppercase tracking-widest font-bold text-stone-800 dark:text-stone-200'
						>{siteConfig.author}</span
					>
					<span class='opacity-50'>&bull;</span>
					<FormattedDate date={pubDate} />
					<span class='opacity-50'>&bull;</span>
					<span>{readTime}</span>
				</div>
			</div>

			<div class='flex flex-wrap justify-center items-center gap-2'>
				{tags.map((tag) => <Tag tag={tag} />)}
			</div>
		</header>

		{
			heroImage && (
				<figure
					class:list={['my-8', heroImageContain && 'flex justify-center']}
				>
					<span
						class:list={[
							'qb-watermark',
							heroImageContain && 'inline-block max-w-[min(100%,28rem)]',
						]}
					>
						<Image
							src={heroImage}
							widths={[640, 960, 1280, 1600, 2200]}
							sizes='(max-width: 640px) 640px, (max-width: 1024px) 960px, (max-width: 1440px) 1280px, 1600px'
							quality={88}
							loading='eager'
							class:list={[
								'rounded-md bg-black',
								heroImageContain
									? 'w-full h-auto max-h-[min(70vh,560px)] object-contain'
									: 'w-full object-cover max-h-[420px] md:max-h-[540px]',
							]}
							alt={`img of ${title}`}
						/>
					</span>
				</figure>
			)
		}

		<hr />

		<div class='article-content'>
			<slot />
			<AuthorBox pubDate={pubDate} readTime={readTime} />
		</div>
	</article>
</BaseLayout>

<script>
	const fnObserver = () => {
		function handleIntersection(
			entries: IntersectionObserverEntry[],
			observer: IntersectionObserver
		) {
			entries.forEach((entry) => {
				const index = document.querySelector(`aside a[data-toc-link][href="#${entry.target.id}"]`)

				if (entry.isIntersecting) {
					index?.classList.remove(
						'border-transparent',
						'text-stone-500',
						'dark:text-stone-400',
						'font-normal'
					)
					index?.classList.add(
						'border-stone-900',
						'dark:border-white',
						'text-stone-900',
						'dark:text-white',
						'font-semibold'
					)
				} else {
					index?.classList.add(
						'border-transparent',
						'text-stone-500',
						'dark:text-stone-400',
						'font-normal'
					)
					index?.classList.remove(
						'border-stone-900',
						'dark:border-white',
						'text-stone-900',
						'dark:text-white',
						'font-semibold'
					)
				}
			})
		}

		const headings = document.querySelectorAll(
			'div.prose h1, div.prose h2, div.prose h3, div.prose h4, div.prose h5, div.prose h6'
		)

		const options = {
			root: null,
			rootMargin: ' 15% 0px 0% 0px ',
			threshold: 1
		}

		const observer = new IntersectionObserver(handleIntersection, options)

		headings.forEach((heading) => {
			observer.observe(heading)
		})
	}
	fnObserver()
	document.addEventListener('astro:after-swap', fnObserver)
</script>
