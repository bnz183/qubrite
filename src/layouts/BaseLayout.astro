---
import BaseHead from '@/components/BaseHead'
import Header from '@/components/Header'
import Footer from '@/components/Footer'
import ProviderTheme from '@/components/ProviderTheme'
import ProviderAnimations from '@/components/ProviderAnimations'
import ConsentBanner from '@/components/ConsentBanner'
const { title, description, image, articleDate } = Astro.props

const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID
---

<html lang='en' class='scroll-smooth'>
	<head>
		{
			gaId && (
				<>
					{/* Google Consent Mode v2 — default denied until user opts in. */}
					<script is:inline>
						window.dataLayer = window.dataLayer || []
						function gtag() {
							dataLayer.push(arguments)
						}
						gtag('consent', 'default', {
							ad_storage: 'denied',
							ad_user_data: 'denied',
							ad_personalization: 'denied',
							analytics_storage: 'denied',
							functionality_storage: 'granted',
							security_storage: 'granted',
							wait_for_update: 500,
						})
					</script>
					{/* Google tag (gtag.js) */}
					<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
					<script is:inline define:vars={{ gaId }}>
						gtag('js', new Date())
						gtag('config', gaId, { anonymize_ip: true })
					</script>
				</>
			)
		}
		<BaseHead title={title} description={description} ogImage={image} articleDate={articleDate} />
		<ProviderTheme />
		<ProviderAnimations />
		<script is:inline>
			// Relative date upgrade (single global pass, no per-component scripts).
			// Never renders future-tense (e.g. "in 5 hours") — clamps anything in the
			// future to "just now" so scheduled posts don't show as upcoming.
			;(function () {
				function format(iso, fallback) {
					try {
						var d = new Date(iso)
						if (isNaN(d.getTime())) return fallback
						var diff = d.getTime() - Date.now()
						if (diff >= 0) return 'just now'
						if (diff / 86400000 < -7) {
							return d.toLocaleDateString('en-US', {
								year: 'numeric',
								month: 'short',
								day: 'numeric',
								timeZone: 'UTC',
							})
						}
						var rtf = new Intl.RelativeTimeFormat('en', { numeric: 'auto' })
						var abs = Math.abs(diff)
						if (abs < 60000) return rtf.format(Math.round(diff / 1000), 'second')
						if (abs < 3600000) return rtf.format(Math.round(diff / 60000), 'minute')
						if (abs < 86400000) return rtf.format(Math.round(diff / 3600000), 'hour')
						return rtf.format(Math.round(diff / 86400000), 'day')
					} catch (e) {
						return fallback
					}
				}
				function run() {
					document.querySelectorAll('time[data-pubdate]').forEach(function (el) {
						var iso = el.getAttribute('data-pubdate')
						if (iso) el.textContent = format(iso, el.textContent || '')
					})
				}
				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', run)
				} else {
					run()
				}
			})()
		</script>
	</head>

	<body class='bg-white text-stone-950 dark:bg-[#0a0910] dark:text-white'>
		<main
			class='px-5 sm:mx-auto sm:max-w-2xl sm:px-8 lg:px-0 antialiased md:max-w-6xl grid gap-12 mt-4 overflow-hidden md:overflow-visible'
		>
			<Header />
			<slot />
			<Footer />
		</main>
		{gaId && <ConsentBanner />}
		<style>
			body {
				margin-left: calc(100vw - 100%); /* prevent layout shift */
			}
		</style>
	</body>
</html>
