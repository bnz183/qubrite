---
import { siteConfig } from '@/site-config'

type Props = {
	title?: string
	body?: string
}

const {
	title = 'QuBrite Dispatch',
	body = 'Operator-focused playbooks, system teardowns, and tech reviews. One email, weekly.',
} = Astro.props

const username = siteConfig.buttondownUsername
const action = username
	? `https://buttondown.com/api/emails/embed-subscribe/${username}`
	: undefined
---

<section
	class='not-prose my-12 rounded-sm border border-stone-200 dark:border-stone-800 bg-gradient-to-br from-white to-stone-50 dark:from-[#0e0d13] dark:to-[#0a0910] p-6 sm:p-8'
	aria-label={title}
>
	<div class='flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between'>
		<div class='flex flex-col gap-2 max-w-xl'>
			<div class='flex items-center gap-2'>
				<span
					class='inline-flex h-1.5 w-1.5 rounded-full bg-sky-500 dark:bg-sky-400'
					aria-hidden='true'></span>
				<span
					class='text-[11px] font-bold uppercase tracking-[0.18em] text-stone-700 dark:text-stone-300 font-display'
				>
					Subscribe
				</span>
			</div>
			<h3 class='text-xl sm:text-2xl font-bold text-stone-900 dark:text-white leading-tight font-display tracking-tight'>
				{title}
			</h3>
			<p class='text-[14px] text-stone-600 dark:text-stone-400 leading-relaxed'>{body}</p>
		</div>
		{
			action ? (
				<form
					method='post'
					action={action}
					target='popupwindow'
					onsubmit="window.open(this.action, 'popupwindow', 'scrollbars=yes,width=800,height=600'); return true;"
					class='flex flex-col sm:flex-row gap-2 sm:items-center sm:shrink-0'
				>
					<input type='hidden' name='embed' value='1' />
					<div class='hidden' aria-hidden='true'>
						<label for='bd-hp'>Leave blank</label>
						<input type='text' name='hp' id='bd-hp' tabindex='-1' autocomplete='off' />
					</div>
					<input
						type='email'
						name='email'
						id='bd-email'
						required
						placeholder='you@domain.com'
						class='h-10 px-3 text-sm bg-white dark:bg-[#0a0910] border border-stone-300 dark:border-stone-700 rounded-sm focus:outline-none focus:border-stone-500 dark:focus:border-stone-400 text-stone-900 dark:text-white placeholder:text-stone-400 w-full sm:w-64'
					/>
					<button
						type='submit'
						class='inline-flex items-center justify-center h-10 px-4 text-[12px] font-semibold uppercase tracking-wider rounded-sm bg-stone-900 dark:bg-white text-white dark:text-stone-900 hover:bg-stone-800 dark:hover:bg-stone-100 transition-colors'
					>
						Subscribe
					</button>
				</form>
			) : (
				<div class='flex flex-col gap-2 sm:shrink-0'>
					<p class='text-[13px] text-stone-600 dark:text-stone-400'>
						Newsletter launching soon. Subscribe via{' '}
						<a
							href='/rss.xml'
							class='font-semibold text-stone-900 dark:text-white underline underline-offset-2'
						>
							RSS
						</a>{' '}
						in the meantime.
					</p>
				</div>
			)
		}
	</div>
</section>
