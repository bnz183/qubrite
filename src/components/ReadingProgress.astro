---
// Scroll-driven reading progress bar pinned to the top of the article page.
---

<div
	id='qb-reading-progress'
	class='fixed left-0 top-0 z-50 h-[2px] w-0 bg-gradient-to-r from-sky-500 via-violet-500 to-fuchsia-500 dark:from-sky-400 dark:via-violet-400 dark:to-fuchsia-400 transition-[width] duration-75 will-change-[width] pointer-events-none'
	aria-hidden='true'
>
</div>

<script is:inline>
	;(function () {
		var bar = document.getElementById('qb-reading-progress')
		if (!bar) return
		var article = document.querySelector('article')
		function update() {
			var target = article || document.documentElement
			var rect = target.getBoundingClientRect ? target.getBoundingClientRect() : null
			var docHeight = (article ? article.scrollHeight : document.documentElement.scrollHeight) - window.innerHeight
			var scrolled = article ? -rect.top : window.scrollY
			if (docHeight <= 0) {
				bar.style.width = '0%'
				return
			}
			var pct = Math.min(100, Math.max(0, (scrolled / docHeight) * 100))
			bar.style.width = pct + '%'
		}
		update()
		window.addEventListener('scroll', update, { passive: true })
		window.addEventListener('resize', update, { passive: true })
	})()
</script>
