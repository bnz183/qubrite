---
import { siteConfig } from '@/site-config'
import LinkedinIcon from './icons/LinkedinIcon.astro'

const today = new Date()
---

<footer
	class='w-full px-6 md:px-16 py-12 border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-[#0a0910] text-sm font-medium mt-16'
>
	<div class='max-w-6xl mx-auto flex flex-col gap-8'>
		<div class='flex items-start gap-3 max-w-2xl'>
			<img
				src='/brand/icon.svg'
				alt=''
				width='32'
				height='32'
				class='shrink-0 rounded-sm border border-gray-200 dark:border-gray-800 p-0.5'
			/>
			<div class='flex flex-col gap-1'>
				<span class='text-[13px] font-bold uppercase tracking-wider text-stone-900 dark:text-white'>
					{siteConfig.title}
				</span>
				<p class='text-[13px] leading-relaxed text-stone-600 dark:text-stone-400'>
					{siteConfig.description}
				</p>
			</div>
		</div>

		<div
			class='flex flex-col md:flex-row justify-between items-center gap-8 pt-6 border-t border-gray-200 dark:border-gray-800'
		>
			<div class='text-stone-600 dark:text-stone-300'>
				&copy; {today.getFullYear()}
				{siteConfig.author}. All rights reserved.
			</div>
			<nav class='flex flex-wrap justify-center gap-x-6 gap-y-2 text-stone-700 dark:text-stone-300'>
				<a href='/about/' class='hover:text-stone-900 dark:hover:text-white transition-colors'
					>About</a
				>
				<a href='/contact/' class='hover:text-stone-900 dark:hover:text-white transition-colors'
					>Contact</a
				>
				<a
					href='/editorial-policy/'
					class='hover:text-stone-900 dark:hover:text-white transition-colors'
					>Editorial Policy</a
				>
				<a
					href='/privacy-policy/'
					class='hover:text-stone-900 dark:hover:text-white transition-colors'>Privacy</a
				>
				<a
					href='/affiliate-disclosure/'
					class='hover:text-stone-900 dark:hover:text-white transition-colors'
					>Affiliate Disclosure</a
				>
				<button
					type='button'
					onclick='window.qbOpenConsent && window.qbOpenConsent()'
					class='cursor-pointer bg-transparent border-0 p-0 text-inherit font-inherit hover:text-stone-900 dark:hover:text-white transition-colors'
				>
					Cookie preferences
				</button>
				<a href='/rss.xml' class='hover:text-stone-900 dark:hover:text-white transition-colors'
					>RSS</a
				>
				<a
					href='https://www.linkedin.com/in/qubrite-intelligence-28122a410/'
					aria-label='QuBrite on LinkedIn'
					target='_blank'
					rel='noopener noreferrer'
					class='hover:text-stone-900 dark:hover:text-white transition-colors inline-flex items-center'
				>
					<LinkedinIcon />
				</a>
			</nav>
		</div>
	</div>
</footer>
