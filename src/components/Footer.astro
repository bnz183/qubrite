---
import { siteConfig } from '@/site-config'

const today = new Date()
---

<footer class='w-full px-6 md:px-16 py-12 border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-[#0a0910] text-sm font-medium mt-16'>
	<div class='max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8'>
		<div class='text-stone-500 dark:text-stone-400'>
			&copy; {today.getFullYear()} {siteConfig.author}. All rights reserved.
		</div>
		<nav class='flex flex-wrap justify-center gap-x-6 gap-y-2 text-stone-600 dark:text-stone-400'>
			<a href='/about' class='hover:text-stone-900 dark:hover:text-white transition-colors'>About</a>
			<a href='/contact' class='hover:text-stone-900 dark:hover:text-white transition-colors'>Contact</a>
			<a href='/editorial-policy' class='hover:text-stone-900 dark:hover:text-white transition-colors'>Editorial Policy</a>
			<a href='/privacy-policy' class='hover:text-stone-900 dark:hover:text-white transition-colors'>Privacy</a>
			<a href='/affiliate-disclosure' class='hover:text-stone-900 dark:hover:text-white transition-colors'>Affiliate Disclosure</a>
			<a href='/rss.xml' class='hover:text-stone-900 dark:hover:text-white transition-colors'>RSS</a>
		</nav>
	</div>
</footer>
