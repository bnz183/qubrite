---
import { siteConfig } from '@/site-config'
import '../styles/global.css'

export interface Props {
	title: string
	/** Shorter SERP title; defaults to `title` when omitted. */
	metaTitle?: string
	description?: string
	ogImage?: string | undefined
	articleDate?: string | undefined
	articleModifiedDate?: string | undefined
	robots?: string | undefined
	/**
	 * Optional explicit canonical path or absolute URL.
	 * When omitted, canonicalizes to the current pathname with a trailing slash,
	 * dropping any query string or fragment. This URL is also used verbatim for
	 * og:url and twitter:url so social shares match what search engines see.
	 */
	canonical?: string
}

const {
	title,
	metaTitle,
	description = siteConfig.description,
	ogImage,
	articleDate,
	articleModifiedDate,
	robots,
	canonical,
} = Astro.props

/**
 * Build a single source-of-truth canonical URL.
 * - Strips query string and hash (static pages don't differ by them).
 * - Forces a trailing slash on non-root paths so the canonical always
 *   matches Astro's directory-style output and never 301-chains.
 * - Accepts a `canonical` prop override (path-relative or absolute).
 */
function buildCanonical(): URL {
	if (canonical) return new URL(canonical, siteConfig.site)
	let path = Astro.url.pathname || '/'
	if (path !== '/' && !path.endsWith('/')) path = `${path}/`
	return new URL(path, siteConfig.site)
}

const canonicalURL = buildCanonical()
const socialImageURL = new URL(ogImage ? ogImage : '/open-graph.png', canonicalURL).href

const titleSeparator = '•'
const documentTitle = metaTitle ?? title

const siteTitle = `${documentTitle} ${titleSeparator} ${siteConfig.title}`
---

<!-- Global Metadata -->
<meta charset='utf-8' />
<meta name='viewport' content='width=device-width,initial-scale=1' />
<link rel='icon' href='/favicon.svg' type='image/svg+xml' />
<link rel='icon' href='/brand/icon.svg' sizes='any' />
<link rel='apple-touch-icon' href='/brand/icon.svg' />
<link rel='mask-icon' href='/favicon.svg' color='#0a0910' />
<meta name='theme-color' content='#0a0910' />
<meta name='generator' content={Astro.generator} />
{robots && <meta name='robots' content={robots} />}

<!-- Canonical URL -->
<link rel='canonical' href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{siteTitle}</title>

<!-- SEO -->
<meta name='title' content={siteTitle} />
<meta name='description' content={description} />
<meta name='author' content={siteConfig.authorName} />

<!-- Open Graph / Facebook -->
<meta property='og:type' content={articleDate ? 'article' : 'website'} />
<meta property='og:url' content={canonicalURL.href} />
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:image' content={socialImageURL} />
<meta property='og:site_name' content={siteConfig.title} />
<meta property='og:locale' content={siteConfig.ogLocale} />
{
	articleDate && (
		<>
			<meta property='article:author' content={siteConfig.authorName} />
			<meta property='article:published_time' content={articleDate} />
			{articleModifiedDate && (
				<meta property='article:modified_time' content={articleModifiedDate} />
			)}
		</>
	)
}

<!-- Twitter -->
<meta property='twitter:card' content='summary_large_image' />
<meta property='twitter:url' content={canonicalURL.href} />
<meta property='twitter:title' content={title} />
<meta property='twitter:description' content={description} />
<meta property='twitter:image' content={socialImageURL} />

<!-- RSS auto-discovery -->
<link rel='alternate' type='application/rss+xml' title={siteConfig.title} href='/rss.xml' />
