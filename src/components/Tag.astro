---
export interface Props {
	tag: string
}
const { tag } = Astro.props
---

<a href={`/tags/${encodeURIComponent(tag.toLowerCase())}`} aria-label={tag}>
	<span
		class='inline-flex items-center px-2 py-1 text-[11px] font-bold uppercase tracking-wider rounded-sm border border-gray-200 dark:border-gray-800 text-stone-700 dark:text-stone-300 hover:text-stone-950 dark:hover:text-white hover:border-stone-400 dark:hover:border-stone-600 transition-colors'
	>
		{tag ?? 'Blog Tag'}
	</span>
</a>
