---
import { sluglify } from '@/utils'

export interface Props {
	tag: string
}
const { tag } = Astro.props
const slug = sluglify(tag)
---

<a
	href={`/tags/${slug}/`}
	aria-label={`More articles tagged ${tag}`}
	class='inline-flex items-center px-2.5 py-1 text-[11px] font-semibold tracking-wide rounded-sm border border-stone-200 dark:border-stone-800 text-stone-700 dark:text-stone-300 hover:text-stone-950 dark:hover:text-white hover:border-stone-400 dark:hover:border-stone-600 transition-colors'
	style='font-family: "Space Grotesk", "Inter", sans-serif;'
>
	{tag}
</a>
