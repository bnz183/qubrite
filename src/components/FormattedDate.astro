---
export interface Props {
	date: Date
	class?: string
}

const { date, class: className = 'text-sm font-bold text-opacity-60' } = Astro.props

const absolute = date.toLocaleDateString('en-us', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
	timeZone: 'UTC',
})
---

<time
	class={className}
	datetime={date.toISOString()}
	data-pubdate={date.toISOString()}
	title={absolute}
>
	{absolute}
</time>
{/* Relative-date upgrade script lives in BaseLayout — kept out of flow content to avoid duplicated bundled scripts. */}
