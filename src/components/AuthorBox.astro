---
import FormattedDate from '@/components/FormattedDate'

type Props = {
	pubDate: Date
	readTime: string
}

const { pubDate, readTime } = Astro.props
---

<section
	class='mt-12 pt-6 border-t border-gray-200 dark:border-gray-800 flex items-start gap-4 not-prose'
>
	<img
		src='/brand/icon.svg'
		alt=''
		width='40'
		height='40'
		class='rounded-sm border border-gray-200 dark:border-gray-800 p-1 shrink-0'
	/>
	<div class='flex flex-col gap-1'>
		<span class='text-[13px] font-bold uppercase tracking-wider text-stone-900 dark:text-white'>
			QuBrite Editorial
		</span>
		<span class='text-[13px] text-stone-600 dark:text-stone-400'>
			Operator-focused analysis. Reviewed and edited by the QuBrite desk.
		</span>
		<span class='text-[12px] text-stone-500 dark:text-stone-500'>
			Published <FormattedDate date={pubDate} /> · {readTime}
		</span>
	</div>
</section>
