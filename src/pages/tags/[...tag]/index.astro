---
import BaseLayout from '@/layouts/BaseLayout'
import ListPosts from '@/components/ListPosts'
import { getTags, getPostByTag, getRelatedTags } from '@/utils'

export async function getStaticPaths() {
	const tags = await getTags()
	return tags.map(({ slug, label }) => ({
		params: { tag: slug },
		props: { slug, label },
	}))
}

type Props = { slug: string; label: string }

const { slug, label } = Astro.props as Props
const posts = await getPostByTag(slug)
const relatedTags = await getRelatedTags(slug, 10)

const postCount = posts.length
const description = `${postCount} article${postCount === 1 ? '' : 's'} on ${label} from QuBrite — independent technical coverage and field notes.`
const showRelated = relatedTags.length > 0 && postCount < 3
---

<BaseLayout title={label} description={description}>
	<section class='mt-6 mb-10 pb-8 border-b border-stone-200 dark:border-stone-800'>
		<nav
			aria-label='Breadcrumb'
			class='text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500 dark:text-stone-400 mb-4'
		>
			<ol class='flex flex-wrap items-center gap-x-2 gap-y-1'>
				<li>
					<a href='/' class='hover:text-stone-900 dark:hover:text-white transition-colors'>Home</a>
				</li>
				<li class='flex items-center gap-2'>
					<span class='opacity-40'>/</span>
					<a
						href='/tags/'
						class='hover:text-stone-900 dark:hover:text-white transition-colors'
					>
						Topics
					</a>
				</li>
				<li class='flex items-center gap-2'>
					<span class='opacity-40'>/</span>
					<span class='text-stone-700 dark:text-stone-300'>{label}</span>
				</li>
			</ol>
		</nav>

		<span
			class='inline-block text-[11px] font-bold uppercase tracking-[0.18em] text-sky-700 dark:text-sky-300 mb-3'
		>
			Topic
		</span>
		<h1
			class='text-3xl sm:text-4xl md:text-5xl font-bold leading-tight -tracking-wide text-stone-900 dark:text-white'
		>
			{label}
		</h1>
		<p class='mt-3 text-stone-600 dark:text-stone-400 text-[15px]'>{description}</p>
	</section>

	<ListPosts posts={posts} />

	{
		showRelated && (
			<section class='mt-12 pt-8 border-t border-stone-200 dark:border-stone-800'>
				<div class='flex items-center gap-2 mb-4'>
					<span
						class='inline-flex h-1.5 w-1.5 rounded-full bg-violet-500 dark:bg-violet-400'
						aria-hidden='true'
					/>
					<h2 class='text-[11px] font-bold uppercase tracking-[0.18em] text-stone-700 dark:text-stone-300 m-0'>
						Related topics
					</h2>
				</div>
				<p class='text-[13px] text-stone-600 dark:text-stone-400 mb-5 max-w-2xl'>
					Tags that appear alongside <span class='font-semibold text-stone-800 dark:text-stone-200'>{label}</span> across our reporting.
				</p>
				<ul class='flex flex-wrap gap-2'>
					{relatedTags.map(({ slug: rs, label: rl }) => (
						<li>
							<a
								href={`/tags/${rs}/`}
								class='inline-flex items-center px-3 py-1.5 text-[12px] font-semibold tracking-wide rounded-sm border border-stone-200 dark:border-stone-800 text-stone-700 dark:text-stone-300 hover:text-stone-950 dark:hover:text-white hover:border-stone-400 dark:hover:border-stone-600 transition-colors'
								style='font-family: "Space Grotesk", "Inter", sans-serif;'
							>
								{rl}
							</a>
						</li>
					))}
				</ul>
			</section>
		)
	}
</BaseLayout>
