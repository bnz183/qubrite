---
import BaseLayout from '@/layouts/BaseLayout'
import ListPosts from '@/components/ListPosts'
import { getTags, getPostByTag } from '@/utils'

export async function getStaticPaths() {
	const tags = await getTags()
	return tags.map(({ slug, label }) => ({
		params: { tag: slug },
		props: { slug, label },
	}))
}

type Props = { slug: string; label: string }

const { slug, label } = Astro.props as Props
const posts = await getPostByTag(slug)
const description = `${posts.length} article${posts.length === 1 ? '' : 's'} on ${label} from QuBrite — independent technical coverage and field notes.`
---

<BaseLayout title={label} description={description}>
	<section class='mt-6 mb-10 pb-8 border-b border-stone-200 dark:border-stone-800'>
		<nav
			aria-label='Breadcrumb'
			class='text-[11px] font-semibold uppercase tracking-[0.16em] text-stone-500 dark:text-stone-400 mb-4'
		>
			<ol class='flex flex-wrap items-center gap-x-2 gap-y-1'>
				<li>
					<a href='/' class='hover:text-stone-900 dark:hover:text-white transition-colors'>Home</a>
				</li>
				<li class='flex items-center gap-2'>
					<span class='opacity-40'>/</span>
					<a
						href='/tags/'
						class='hover:text-stone-900 dark:hover:text-white transition-colors'
					>
						Topics
					</a>
				</li>
				<li class='flex items-center gap-2'>
					<span class='opacity-40'>/</span>
					<span class='text-stone-700 dark:text-stone-300'>{label}</span>
				</li>
			</ol>
		</nav>

		<span
			class='inline-block text-[11px] font-bold uppercase tracking-[0.18em] text-sky-700 dark:text-sky-300 mb-3'
		>
			Topic
		</span>
		<h1
			class='text-3xl sm:text-4xl md:text-5xl font-bold leading-tight -tracking-wide text-stone-900 dark:text-white'
		>
			{label}
		</h1>
		<p class='mt-3 text-stone-600 dark:text-stone-400 text-[15px]'>{description}</p>
	</section>

	<ListPosts posts={posts} />
</BaseLayout>
