---
import BaseLayout from '@/layouts/BaseLayout'
import { getTags } from '@/utils'
const tags = await getTags()
---

<BaseLayout
	title='Topics — QuBrite'
	description='Browse QuBrite by topic — tools, technologies, and concrete subjects covered across our reporting.'
>
	<section class='mt-6 mb-8 pb-8 border-b border-stone-200 dark:border-stone-800'>
		<span
			class='inline-block text-[11px] font-bold uppercase tracking-[0.18em] text-sky-700 dark:text-sky-300 mb-3'
		>
			Index
		</span>
		<h1
			class='text-3xl sm:text-4xl md:text-5xl font-bold leading-tight -tracking-wide text-stone-900 dark:text-white'
		>
			Topics
		</h1>
		<p class='mt-3 text-stone-600 dark:text-stone-400 text-[15px] max-w-2xl'>
			Every named tool, technology, and beat we cover. Click a topic to see every QuBrite
			article in that area.
		</p>
	</section>

	<ul class='flex flex-wrap gap-2'>
		{
			tags.map(({ slug, label }) => (
				<li>
					<a
						href={`/tags/${slug}/`}
						class='inline-flex items-center px-3 py-1.5 text-[12px] font-semibold tracking-wide rounded-sm border border-stone-200 dark:border-stone-800 text-stone-700 dark:text-stone-300 hover:text-stone-950 dark:hover:text-white hover:border-stone-400 dark:hover:border-stone-600 transition-colors'
						style='font-family: "Space Grotesk", "Inter", sans-serif;'
					>
						{label}
					</a>
				</li>
			))
		}
	</ul>
</BaseLayout>
