---
import ListCategories from '@/components/ListCategories'
import ListPosts from '@/components/ListPosts'
import BaseLayout from '@/layouts/BaseLayout'
import { getPosts, sluglify } from '@/utils'
import { CATEGORIES } from '@/data/categories'
import FormattedDate from '@/components/FormattedDate'
import { Image } from 'astro:assets'
import { EDITORS_PICKS } from '@/data/editors-picks'

const MAX_POSTS = 16 // max number of posts to show on the home page
const posts = await getPosts(MAX_POSTS)

const featuredPost = posts[0]
const isFeaturedGeneric =
	featuredPost &&
	(featuredPost.data.heroImage.src.includes('placeholder') ||
		featuredPost.data.heroImage.src.includes('default') ||
		featuredPost.data.heroImage.src.includes('/bg.'))
const latestBriefs = posts.slice(1, 5)
const remainingPosts = posts.slice(5)
const editorsPicksPosts = posts.filter((p) => EDITORS_PICKS.includes(p.id)).slice(0, 3)
---

<BaseLayout title='AI & Web Development, Automation & Tech Systems'>
	<!-- Top Editorial Grid -->
	<div
		class='grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12 pt-8 border-t border-gray-200 dark:border-gray-800'
	>
		<!-- Left Column: Latest Briefs -->
		<div class='lg:col-span-3 flex flex-col gap-6 order-2 lg:order-1'>
			<h2
				class='text-[13px] font-bold uppercase tracking-wider text-stone-800 dark:text-stone-200 border-b border-gray-200 dark:border-gray-800 pb-2'
			>
				Latest Briefs
			</h2>
			<div class='flex flex-col gap-6'>
				{
					latestBriefs.length > 0 ? (
						latestBriefs.map((post) => (
							<article>
								<a href={`/post/${post.id}/`} class='group flex flex-col gap-1'>
									<h3 class='text-[15px] font-semibold leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2'>
										{post.data.title}
									</h3>
									<div class='text-[12px] text-stone-600 dark:text-stone-300 flex items-center gap-2 mt-1 font-medium'>
										<FormattedDate date={post.data.pubDate} />
										<span class='opacity-50'>&bull;</span>
										<span class='uppercase tracking-wider text-[10px] font-bold'>
											{post.data.category}
										</span>
									</div>
								</a>
							</article>
						))
					) : (
						<p class='text-sm text-gray-500'>More updates coming soon.</p>
					)
				}
			</div>
		</div>

		<!-- Center Column: Featured Article -->
		<div class='lg:col-span-6 order-1 lg:order-2'>
			<h2
				class='text-[13px] font-bold uppercase tracking-wider text-stone-800 dark:text-stone-200 border-b border-gray-200 dark:border-gray-800 pb-2 mb-6'
			>
				Featured Analysis
			</h2>
			{
				featuredPost ? (
					<article class='group flex flex-col gap-4'>
						<a
							href={`/post/${featuredPost.id}/`}
							class='block overflow-hidden relative rounded-sm aspect-[16/9] bg-stone-50 dark:bg-[#0c0b10] border border-gray-100 dark:border-gray-800 group/feat'
						>
							{isFeaturedGeneric ? (
								<>
									<div class='absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:32px_32px] transition-transform duration-500 group-hover/feat:scale-105' />
									<div class='absolute inset-0 flex items-center justify-center pointer-events-none z-10'>
										<span class='text-3xl md:text-5xl font-bold uppercase tracking-[0.15em] text-stone-800/80 dark:text-stone-200/80 drop-shadow-md'>
											{featuredPost.data.category}
										</span>
									</div>
								</>
							) : (
								<>
									<Image
										src={featuredPost.data.heroImage}
										width={800}
										height={400}
										format='webp'
										class='w-full h-full object-cover hover:scale-105 transition-transform duration-500 bg-gray-100 dark:bg-gray-800 text-transparent'
										alt={`Cover image for ${featuredPost.data.title}`}
									/>
									<div class='absolute top-3 left-3 bg-black/90 dark:bg-white/90 text-white dark:text-black px-2 py-1 text-[11px] font-bold uppercase tracking-wider rounded-sm backdrop-blur-sm shadow-sm z-10'>
										{featuredPost.data.category}
									</div>
								</>
							)}
						</a>
						<div class='flex flex-col gap-2'>
							<div class='text-[13px] text-stone-600 dark:text-stone-300 flex items-center gap-2 font-semibold uppercase tracking-wider mb-1'>
								<FormattedDate date={featuredPost.data.pubDate} />
							</div>
							<a
								href={`/post/${featuredPost.id}/`}
								class='group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors'
							>
								<h3 class='text-3xl md:text-4xl font-bold leading-tight -tracking-wide line-clamp-3'>
									{featuredPost.data.title}
								</h3>
							</a>
							<p class='text-[15px] text-stone-700 dark:text-stone-200 line-clamp-3 mt-3 leading-relaxed font-medium'>
								{featuredPost.data.description}
							</p>
							<a
								href={`/post/${featuredPost.id}/`}
								class='mt-2 inline-flex items-center text-sm font-bold uppercase tracking-wide hover:text-blue-600 dark:hover:text-blue-400 transition-colors group-hover:underline decoration-2 underline-offset-4'
							>
								Read Analysis &rarr;
							</a>
						</div>
					</article>
				) : (
					<p class='text-sm text-gray-500'>No featured posts yet.</p>
				)
			}
		</div>

		<!-- Right Column: Editor's Picks / Newsletter -->
		<div class='lg:col-span-3 flex flex-col gap-8 order-3 lg:order-3'>
			<div class='flex flex-col gap-6'>
				<h2
					class='text-[13px] font-bold uppercase tracking-wider text-stone-800 dark:text-stone-200 border-b border-gray-200 dark:border-gray-800 pb-2'
				>
					Editor's Picks
				</h2>
				<div class='flex flex-col gap-5'>
					{
						editorsPicksPosts.map((post) => (
							<article>
								<a href={`/post/${post.id}/`} class='group flex flex-col gap-1'>
									<h3 class='text-[15px] font-semibold leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2'>
										{post.data.title}
									</h3>
									<div class='text-[12px] text-stone-600 dark:text-stone-300 flex items-center gap-2 mt-1 font-medium'>
										<FormattedDate date={post.data.pubDate} />
									</div>
								</a>
							</article>
						))
					}
				</div>
			</div>

			<div
				class='bg-gray-50 dark:bg-[#111] border border-gray-200 dark:border-gray-800 p-5 rounded-sm'
			>
				<h3 class='text-md font-bold mb-2'>QuBrite Dispatch</h3>
				<p class='text-sm text-gray-700 dark:text-gray-300 mb-4'>
					Operator-focused playbooks, system teardowns, and tech reviews delivered to your inbox.
				</p>
				<form class='flex flex-col gap-2' onsubmit='event.preventDefault();'>
					<input
						type='email'
						placeholder='Email address'
						class='px-3 py-2 text-sm bg-white dark:bg-black border border-gray-300 dark:border-gray-700 rounded-sm focus:outline-none focus:border-gray-500 w-full'
					/>
					<button
						type='submit'
						class='bg-black dark:bg-white text-white dark:text-black px-3 py-2 text-sm font-bold w-full rounded-sm hover:opacity-90 transition-opacity'
						>Subscribe</button
					>
				</form>
				<p class='text-xs text-gray-500 mt-3 text-center'>No noise. Unsubscribe anytime.</p>
			</div>
		</div>
	</div>

	<!-- Below the Fold: Category Sections -->
	<div
		class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-12 mb-16 border-t border-gray-200 dark:border-gray-800 pt-8'
	>
		{
			CATEGORIES.map((cat) => {
				const catPosts = posts.filter((p) => p.data.category === cat).slice(0, 3)
				if (catPosts.length === 0) return null
				return (
					<div class='flex flex-col gap-4'>
						<h2 class='text-[13px] font-bold uppercase tracking-wider text-stone-800 dark:text-stone-200 border-b border-gray-200 dark:border-gray-800 pb-2 flex justify-between items-center'>
							{cat}
							<a
								href={`/category/${sluglify(cat)}/1/`}
								class='text-[11px] text-stone-600 hover:text-stone-900 dark:text-stone-400 dark:hover:text-white transition-colors uppercase tracking-widest'
							>
								View All
							</a>
						</h2>
						<div class='flex flex-col gap-5'>
							{catPosts.map((p) => (
								<a href={`/post/${p.id}/`} class='group flex flex-col gap-1'>
									<h3 class='text-[15px] font-semibold leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2'>
										{p.data.title}
									</h3>
									<div class='text-[12px] text-stone-600 dark:text-stone-300 flex items-center gap-2 mt-1 font-medium'>
										<FormattedDate date={p.data.pubDate} />
									</div>
								</a>
							))}
						</div>
					</div>
				)
			})
		}
	</div>

	<!-- Latest Posts Grid -->
	<div class='mt-16 border-t border-gray-200 dark:border-gray-800 pt-8'>
		<h2
			class='text-[15px] font-bold uppercase tracking-wider text-stone-800 dark:text-stone-200 mb-8 border-b border-gray-200 dark:border-gray-800 pb-2'
		>
			Latest from the Desk
		</h2>
		{
			remainingPosts.length > 0 ? (
				<ListPosts FirstBig={false} posts={remainingPosts} />
			) : (
				<ListPosts FirstBig={false} posts={posts} />
			)
		}
	</div>
</BaseLayout>
