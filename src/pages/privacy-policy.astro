---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Privacy Policy" description="Privacy policy for QuBrite.">
  <main class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-4xl font-bold">Privacy Policy</h1>
    <p class="mt-6">This site may collect basic analytics data to understand traffic and improve content. If affiliate links or advertising are used, third-party services may process data according to their own policies.</p>
    <p class="mt-4">QuBrite values privacy tech and attempts to minimize tracking where possible.</p>
  </main>
</BaseLayout>
