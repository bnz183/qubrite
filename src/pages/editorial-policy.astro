---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Editorial Policy" description="Editorial standards for System Signal.">
  <main class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-4xl font-bold">Editorial Policy</h1>
    <p class="mt-6">System Signal focuses on practical, technical, and commercially relevant coverage of AI, automation, security, privacy, hardware, software, and business systems.</p>
    <p class="mt-4">AI may assist drafting and research, but articles should be reviewed before publication.</p>
  </main>
</BaseLayout>
