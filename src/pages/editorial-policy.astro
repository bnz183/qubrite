---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Editorial Policy" description="Editorial standards for QuBrite.">
  <main class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-4xl font-bold">Editorial Policy</h1>
    <p class="mt-6">QuBrite focuses on practical, technical, and commercially relevant coverage of AI web building, automation systems, cyber labs, privacy tech, hardware, and business systems.</p>
    <p class="mt-4">AI may assist drafting and research, but articles are rigorously reviewed to ensure operator-focused, non-hype quality.</p>
  </main>
</BaseLayout>
