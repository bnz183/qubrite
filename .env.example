# Copy to .env for local builds (never commit .env).
# Cloudflare Pages: set these in project Environment variables.

# GA4 — defaults to G-XX3Z7TZP3Y in src/data/site.config.ts when unset
PUBLIC_GA_MEASUREMENT_ID=G-XX3Z7TZP3Y

# Buttondown newsletter username (enables subscribe forms site-wide)
PUBLIC_BUTTONDOWN_USERNAME=

# IndexNow API key (32-char hex). Overrides public/indexnow-key.txt when set.
INDEXNOW_KEY=
